    "deploy:xlayer-mainnet": "node -e \"process.env.CHAIN_LABEL='xlayer-mainnet'; process.env.RPC_URL=process.env.XLAYER_RPC||'https://rpc.xlayer.tech'; require('./scripts/deploy.js')\""
